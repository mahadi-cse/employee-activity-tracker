# Consolidated Gitignore for Root Repo

# Dependencies
node_modules/
.next/
**/node_modules/
.pnp
.pnp.*
.yarn/*

# Next.js (Client)
client/.next/
client/out/
client/build/
client/next-env.d.ts

# Prisma (Server)
server/.env
server/prisma/dev.db
server/prisma/dev.db-journal
server/generated/prisma/

# Testing
**/coverage/

# OS/Misc
.DS_Store
Thumbs.db
*.pem
.vercel
*.tsbuildinfo

# Logs
*-debug.log*
*-error.log*

# Extension
extension/*.zip
extension/*.crx
